// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // Убираем output, чтобы он генерировался в node_modules
   /*  output   = "../src/generated/prisma"
  moduleFormat = "cjs" */
}
  
enum Role {
 USER
 ADMIN
}

datasource db {
  provider = "postgresql"
}



/* В модели User пароль хранится в
поле password. Технически это работает, потому что туда записывается хеш, но по
читаемости и хорошей практике лучше назвать поле passwordHash, чтобы сразу было
понятно, что открытый пароль в БД не хранится. */
// Таблица: User
model User {
  id        String   @id @default(uuid()) // Уникальный идентификатор пользователя
  name      String
  email     String   @unique
  password  String   // Хранение пароля в виде хэша для безопасности
  createdAt DateTime @default(now()) // Дата и время создания пользователя
   role      Role     @default(USER)
  updatedAt DateTime @updatedAt // Дата и время последнего обновления пользователя
  tasks     Task[] // Один пользователь может иметь много задач
}

// Таблица: Board
model Board {
  id          String   @id @default(uuid()) // Уникальный идентификатор доски
  title       String   // Название доски
  description String?  // Опциональное описание доски
  createdAt   DateTime @default(now()) // Дата создания
  tasks       Task[] // Связь One-to-Many с задачами
}

// Enum для статусов задач
enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

// Таблица: Task
model Task {
  id          String       @id @default(uuid()) // Уникальный идентификатор задачи
  title       String
  description String?                                   // Опциональное описание
  status      TaskStatus @default(TODO)               // Статус задачи
  createdAt   DateTime  @default(now())               // Дата создания

  // Внешние ключи
  boardId String
  userId  String

  // Связи
  board Board @relation(fields: [boardId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
}